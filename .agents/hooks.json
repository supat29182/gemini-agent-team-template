{
  "brain-linter-and-gitnexus": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx gitnexus analyze > /dev/stderr; echo '{}'",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "python3 scripts/brain_linter.py > /dev/stderr; echo '{}'",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 scripts/log_rotation.py > /dev/stderr; echo '{}'",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
